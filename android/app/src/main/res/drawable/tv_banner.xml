<?xml version="1.0" encoding="utf-8"?>
<!-- Bannière du lanceur Android TV (référencée par android:banner dans le
     manifeste). Format recommandé 320×180. Layer-list : fond sombre de l'app
     + logo centré (réutilise le foreground du launcher adaptatif).
     Voir docs/native-port.md §4 (Phase 2d). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/tv_banner_background" />
    <item
        android:width="160dp"
        android:height="160dp"
        android:gravity="center"
        android:drawable="@mipmap/ic_launcher_foreground" />
</layer-list>
