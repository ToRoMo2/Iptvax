{
  "name": "iptv-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:proxy": "node server/proxy.cjs",
    "build": "tsc -b && vite build",
    "build:tv": "cross-env VITE_API_BASE_URL=https://PLACEHOLDER_URL npm run build",
    "build:capacitor": "cross-env VITE_RUNTIME=capacitor npm run build",
    "build:native": "npm run build:capacitor",
    "build:tizen": "node scripts/build-tizen.mjs",
    "build:webos": "node scripts/build-webos.mjs",
    "cap:sync": "npm run build:capacitor && cap sync",
    "cap:android": "cap open android",
    "fetch:mpv": "node scripts/fetch-mpv.mjs",
    "electron:dev": "npm run fetch:mpv && electron .",
    "electron:start": "npm run fetch:mpv && npm run build && electron .",
    "electron:build": "npm run fetch:mpv && npm run build && electron-builder",
    "start": "NODE_ENV=production node server/proxy.cjs",
    "server": "node server/proxy.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "gen:icons": "node scripts/generate-android-icons.mjs",
    "gen:icons:win": "node scripts/generate-win-icon.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.5",
    "@capacitor/app": "^7.1.2",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/core": "^7.6.5",
    "@noriginmedia/norigin-spatial-navigation": "^3.1.0",
    "@supabase/supabase-js": "^2.105.4",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "hls.js": "^1.6.16",
    "mpegts.js": "^1.8.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.5",
    "@eslint/js": "^9.13.0",
    "@types/hls.js": "^1.0.0",
    "@types/node": "^25.6.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "sharp": "^0.34.5",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10"
  },
  "build": {
    "appId": "com.iptvax.app",
    "productName": "Iptvax",
    "asar": true,
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**"
    ],
    "files": [
      "dist/**",
      "electron/**",
      "!electron/spike-*.cjs",
      "server/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/mpv/mpv.exe",
        "to": "mpv/mpv.exe"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
