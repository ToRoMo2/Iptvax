# Backend URL pour les builds TV/mobile.
# Laisser vide pour le web co-localisé (le frontend et le serveur tournent ensemble).
# Exemple TV/mobile : VITE_API_BASE_URL=https://mon-api.example.com
VITE_API_BASE_URL=

# CORS — origines autorisées par le serveur standalone (séparées par virgule).
# Utiliser * en développement ou pour un accès public.
# Exemple restreint : ALLOWED_ORIGINS=https://iptvax.com,https://www.iptvax.com
ALLOWED_ORIGINS=*

# Port du serveur standalone (npm run server). Défaut : 4000.
PORT=4000

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# TMDB (optionnel — l'app fonctionne sans)
VITE_TMDB_API_KEY=your-tmdb-key

# URL publique du site web (vitrine). Encodée dans le QR code d'appairage TV
# (Phase 2f) : la TV pointe vers VITE_WEB_URL/tv-link. OBLIGATOIRE pour les
# builds natifs TV (window.location.origin y vaut https://localhost).
# Penser à ajouter VITE_WEB_URL/tv-link aux Redirect URLs Supabase (OAuth web).
VITE_WEB_URL=https://iptvax.com

# Forcer le tier Premium en développement (jamais en production)
# VITE_DEV_FORCE_PREMIUM=true
